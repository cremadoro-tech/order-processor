# MCP認証情報テンプレート
# このファイルをコピーして .env を作成し、各値を埋めてください
# .env はGit管理対象外です（.gitignoreに追加済み）

# ==========================================
# MCP連携
# ==========================================

# GitHub Personal Access Token
# 取得方法: https://github.com/settings/tokens
# 必要なスコープ: repo, read:user, project
GITHUB_PERSONAL_ACCESS_TOKEN=

# Google OAuth 2.0
# 取得方法: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets スプレッドシートID
# URLのhttps://docs.google.com/spreadsheets/d/{ここがID}/editの部分
GOOGLE_SPREADSHEET_ID=

# ==========================================
# Nint（ECトレンド分析ツール）
# ==========================================
NINT_EMAIL=
NINT_PASSWORD=

# ==========================================
# EC各サイト 管理画面ログイン情報
# ==========================================

# Amazon セラーセントラル
AMAZON_SELLER_EMAIL=
AMAZON_SELLER_PASSWORD=

# 楽天 RMS
RAKUTEN_SELLER_ID=
RAKUTEN_SELLER_PASSWORD=

# Yahoo!ショッピング ストアクリエイター
YAHOO_STORE_ID=
YAHOO_PASSWORD=

# Shopify（API不使用・Playwrightスクレイピング）
# ストアのURL「https://admin.shopify.com/store/{ここがSTORE_HANDLE}」の部分
SHOPIFY_STORE_HANDLE=

# ギフトモール
GIFTMALL_EMAIL=
GIFTMALL_PASSWORD=

# AuPay マーケット
AUPAY_EMAIL=
AUPAY_PASSWORD=

# Qoo10
QOO10_SELLER_ID=
QOO10_PASSWORD=
